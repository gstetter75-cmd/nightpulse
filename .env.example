# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Frontend (public)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
NEXT_PUBLIC_MAPLIBRE_STYLE=https://basemaps.cartocdn.com/gl/dark-matter-gl-style/style.json

# Pipeline
EVENTBRITE_API_KEY=your-eventbrite-key
PIPELINE_DEFAULT_LAT=52.52
PIPELINE_DEFAULT_LNG=13.405
PIPELINE_DEFAULT_RADIUS_KM=25

# JSON fallback (used when SUPABASE_URL is not set)
JSON_OUTPUT_PATH=packages/frontend/public/data/events.json
